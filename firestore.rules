rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, 'user' or 'admin')
    //   - createdAt: timestamp (required)
    //
    // Collection: research
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, owner)
    //   - query: string (required)
    //   - answer: string (required)
    //   - sources: list (required)
    //   - thinking: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: monitors
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, owner)
    //   - query: string (required)
    //   - frequency: string (required, 'daily' or 'weekly')
    //   - status: string (required, 'active' or 'paused')
    //   - lastCheck: timestamp (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "shirolawalap@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidResearch(data) {
      return data.keys().hasAll(['uid', 'query', 'answer', 'sources', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.query is string && data.query.size() > 0 && data.query.size() < 1000 &&
             data.answer is string && data.answer.size() > 0 && data.answer.size() < 100000 &&
             data.sources is list &&
             data.createdAt is timestamp;
    }

    function isValidMonitor(data) {
      return data.keys().hasAll(['uid', 'query', 'frequency', 'status', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.query is string && data.query.size() > 0 && data.query.size() < 500 &&
             data.frequency in ['daily', 'weekly'] &&
             data.status in ['active', 'paused'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /research/{researchId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidResearch(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /monitors/{monitorId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidMonitor(request.resource.data);
      allow update: if isDocOwner() && isValidMonitor(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
